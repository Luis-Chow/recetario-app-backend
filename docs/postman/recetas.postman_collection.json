{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d",
    "name": "RecetasApp API",
    "description": "Coleccion completa de la API de RecetasApp. Incluye endpoints publicos (health, register, login) y autenticados (usuarios, recetas, grupos y relaciones receta-grupo). Las variables de coleccion (baseUrl, token, userId, recipeId, groupId) se rellenan automaticamente desde los scripts de test.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "description": "Endpoint publico de comprobacion de estado del servicio.",
      "item": [
        {
          "name": "GET health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Comprueba que el backend esta vivo. Devuelve un objeto de estado simple."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Endpoints publicos de registro e inicio de sesion. Tras una respuesta exitosa, el token y el userId se guardan automaticamente como variables de coleccion.",
      "item": [
        {
          "name": "POST register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  var data = pm.response.json();",
                  "  if (data && data.token) {",
                  "    pm.collectionVariables.set('token', data.token);",
                  "  }",
                  "  if (data && data.user && data.user.id) {",
                  "    pm.collectionVariables.set('userId', data.user.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Luis Demo\",\n  \"email\": \"luis.demo@example.com\",\n  \"password\": \"Secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Crea una cuenta de usuario nueva. Devuelve token JWT y datos del usuario. El script de test guarda token y userId como variables de coleccion."
          },
          "response": []
        },
        {
          "name": "POST login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  var data = pm.response.json();",
                  "  if (data && data.token) {",
                  "    pm.collectionVariables.set('token', data.token);",
                  "  }",
                  "  if (data && data.user && data.user.id) {",
                  "    pm.collectionVariables.set('userId', data.user.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"luis.demo@example.com\",\n  \"password\": \"Secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Inicia sesion con email y contrasena. Devuelve token JWT y datos del usuario. El script de test guarda token y userId como variables de coleccion."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
