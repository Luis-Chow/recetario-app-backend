    {
      "name": "Recipes",
      "description": "CRUD de recetas del usuario autenticado. Soporta filtros por propias (mine=true) y por grupo (groupId).",
      "item": [
        {
          "name": "GET recipes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/recipes?mine=true&groupId={{groupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "recipes"],
              "query": [
                {
                  "key": "mine",
                  "value": "true",
                  "description": "Si es true, devuelve solo las recetas del usuario autenticado.",
                  "disabled": true
                },
                {
                  "key": "groupId",
                  "value": "{{groupId}}",
                  "description": "Filtra recetas que pertenezcan a este grupo.",
                  "disabled": true
                }
              ]
            },
            "description": "Lista recetas accesibles para el usuario. Acepta los filtros opcionales mine=true y groupId=ID."
          },
          "response": []
        },
        {
          "name": "POST recipe",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  var data = pm.response.json();",
                  "  if (data && data.recipe && data.recipe.id) {",
                  "    pm.collectionVariables.set('recipeId', data.recipe.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tortilla de patatas\",\n  \"description\": \"Tortilla clasica espanola jugosa.\",\n  \"ingredients\": [\n    { \"name\": \"Patatas\", \"quantity\": 4, \"unit\": \"ud\" },\n    { \"name\": \"Huevos\", \"quantity\": 6, \"unit\": \"ud\" },\n    { \"name\": \"Cebolla\", \"quantity\": 1, \"unit\": \"ud\" },\n    { \"name\": \"Aceite de oliva\", \"quantity\": 200, \"unit\": \"ml\" },\n    { \"name\": \"Sal\", \"quantity\": 1, \"unit\": \"pizca\" }\n  ],\n  \"steps\": [\n    \"Pelar y cortar las patatas en laminas finas.\",\n    \"Freir las patatas con la cebolla a fuego medio hasta que esten tiernas.\",\n    \"Batir los huevos con sal y mezclar con las patatas escurridas.\",\n    \"Cuajar la tortilla en sarten por ambos lados.\"\n  ],\n  \"prepTime\": 45,\n  \"servings\": 4,\n  \"isPublic\": true,\n  \"groupIds\": [\"{{groupId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/recipes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "recipes"]
            },
            "description": "Crea una nueva receta para el usuario autenticado. El script de test guarda el id devuelto en la variable recipeId."
          },
          "response": []
        },
        {
          "name": "GET recipe by id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/recipes/{{recipeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "recipes", "{{recipeId}}"]
            },
            "description": "Devuelve la receta cuyo id coincide con recipeId."
          },
          "response": []
        },
        {
          "name": "PATCH recipe",
