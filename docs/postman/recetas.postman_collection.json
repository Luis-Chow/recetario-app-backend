    {
      "name": "Group-Recipe relations",
      "description": "Endpoints para asociar y desasociar recetas a grupos sin borrar la receta.",
      "item": [
        {
          "name": "POST attach recipe to group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
